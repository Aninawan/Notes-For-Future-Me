  .key-insight {
    background: var(--highlight);
    border-left: 4px solid var(--gold);
    padding: 0.9rem 1.25rem;
    border-radius: 0 4px 4px 0;
    font-size: 0.88rem;
    color: var(--slate);
    margin-top: 1rem;
