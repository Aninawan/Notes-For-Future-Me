// ══════════════ QUIZ STATE ══════════════
let currentQuestions = [];
let currentIdx = 0;
let score = 0;
let answered = false;

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function startQuiz() {
  currentQuestions = shuffle(POOL).slice(0, 10);
  currentIdx = 0;
  score = 0;
  answered = false;
  document.getElementById('score-panel').classList.remove('show');
  renderQuestion();
}

function renderQuestion() {
  answered = false;
  const q = currentQuestions[currentIdx];
  const total = currentQuestions.length;

  document.getElementById('q-counter').textContent = `${currentIdx + 1} / ${total}`;
  document.getElementById('progress-fill').style.width = `${((currentIdx + 1) / total) * 100}%`;

  const letters = ['A','B','C','D'];
  const choicesHTML = q.choices.map((c, i) => `
    <button class="choice-btn" onclick="selectAnswer(${i})" id="choice-${i}">
      <span class="choice-letter">${letters[i]}</span>
      <span>${c}</span>
    </button>
  `).join('');

  document.getElementById('quiz-area').innerHTML = `
    <div class="q-card">
      <div class="q-number">Question ${currentIdx + 1} of ${total}</div>
      <div class="q-text">${q.q}</div>
      <div class="choices">${choicesHTML}</div>
      <div class="feedback-strip" id="feedback"></div>
    </div>
    <div class="quiz-nav">
      <span></span>
      <button class="btn btn-primary" id="next-btn" onclick="nextQuestion()" disabled>
        ${currentIdx === total - 1 ? 'See Results →' : 'Next Question →'}
      </button>
    </div>
  `;
}

function selectAnswer(chosen) {
  if (answered) return;
  answered = true;

  const q = currentQuestions[currentIdx];
  const correct = q.ans;
  const fb = document.getElementById('feedback');

  for (let i = 0; i < 4; i++) {
    const btn = document.getElementById(`choice-${i}`);
    btn.disabled = true;
    if (i === correct) btn.classList.add('reveal-correct');
    if (i === chosen && chosen !== correct) btn.classList.add('wrong');
    if (i === chosen && chosen === correct) btn.classList.add('correct');
  }

  if (chosen === correct) {
    score++;
    fb.textContent = '✓ Correct! ' + q.expl;
    fb.className = 'feedback-strip show correct-fb';
  } else {
    fb.textContent = '✗ Incorrect. ' + q.expl;
    fb.className = 'feedback-strip show wrong-fb';
  }

  document.getElementById('next-btn').disabled = false;
}

function nextQuestion() {
  currentIdx++;
  if (currentIdx >= currentQuestions.length) {
    showScore();
  } else {
    renderQuestion();
  }
}

function showScore() {
  document.getElementById('quiz-area').innerHTML = '';
  document.getElementById('q-counter').textContent = 'Complete!';
  document.getElementById('progress-fill').style.width = '100%';

  const wrong = 10 - score;
  let verdict, sub;
  if (score === 10) { verdict = "Perfect Score!"; sub = "Outstanding mastery of production theory."; }
  else if (score >= 8) { verdict = "Excellent Work"; sub = "Strong command of the material. Review any missed concepts."; }
  else if (score >= 6) { verdict = "Good Effort"; sub = "Solid foundation. Revisit the summary for weaker areas."; }
  else if (score >= 4) { verdict = "Keep Studying"; sub = "Review the lesson summary and try again."; }
  else { verdict = "Needs Review"; sub = "Return to the Lesson Summary section and work through each concept carefully."; }

  document.getElementById('score-num').textContent = score;
  document.getElementById('score-verdict').textContent = verdict;
  document.getElementById('score-sub').textContent = sub;
  document.getElementById('bd-correct').textContent = score;
  document.getElementById('bd-wrong').textContent = wrong;
  document.getElementById('score-panel').classList.add('show');
}

function restartQuiz() {
  document.getElementById('score-panel').classList.remove('show');
  startQuiz();
}

// ══════════════ TAB SWITCHING ══════════════
function switchTab(tab, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(tab).classList.add('active');
  btn.classList.add('active');
  if (tab === 'quiz' && currentQuestions.length === 0) startQuiz();
}

// Fix duplicate ans property in one question
POOL[8].ans = 1; // 0.50

// init
document.addEventListener('DOMContentLoaded', () => {});
