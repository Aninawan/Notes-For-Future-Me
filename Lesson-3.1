    display: none;
  }
  .feedback-strip.show { display: block; animation: fadeIn 0.25s ease; }
  .feedback-strip.correct-fb { background: #e8f5e9; color: var(--correct); border-left: 3px solid var(--correct); }
  .feedback-strip.wrong-fb { background: #fce4ec; color: var(--wrong); border-left: 3px solid var(--wrong); }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .quiz-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.5rem;
  }

  .score-panel {
    display: none;
    background: white;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3rem 2rem;
    text-align: center;
    box-shadow: 0 4px 20px rgba(26,18,9,0.08);
    animation: slideIn 0.4s ease;
  }
  .score-panel.show { display: block; }
  .score-big {
    font-family: 'Playfair Display', serif;
    font-size: 5rem;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .score-label { color: var(--muted); font-size: 0.9rem; margin-bottom: 1.5rem; }
  .score-verdict {
