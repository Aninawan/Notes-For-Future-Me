    <div class="score-breakdown">
      <div class="breakdown-item"><div class="breakdown-val correct-val" id="bd-correct">0</div><div class="breakdown-lbl">Correct</div></div>
      <div class="breakdown-item"><div class="breakdown-val wrong-val" id="bd-wrong">0</div><div class="breakdown-lbl">Incorrect</div></div>
    </div>
    <button class="btn btn-primary" onclick="restartQuiz()">Try Again with New Questions</button>
  </div>

</div>
</div>

<script>
// ══════════════ QUESTION POOL (50 questions) ══════════════
const POOL = [
  // --- Production Function Basics ---
  {
    q: "A firm's production function Q = f(K, L) represents:",
    choices: ["The minimum cost of producing any output level","The maximum output obtainable from given inputs with a fixed technology","The profit-maximizing combination of inputs","The total expenditure on factors of production"],
    ans: 1,
    expl: "The production function maps input combinations to the maximum technically feasible output."
  },
  {
    q: "In the short run, which statement is most accurate?",
    choices: ["All inputs can be adjusted freely","Only capital is variable; labor is fixed","At least one input is fixed and cannot be varied","All production decisions are reversible"],
    ans: 2,
    expl: "The short run is defined as the period in which at least one input (typically capital) is fixed."
  },
  {
    q: "Which feature distinguishes the long run from the short run in production theory?",
    choices: ["Prices of inputs are fixed in the long run","All inputs become variable in the long run","Diminishing returns disappear in the long run","The production function itself changes in the long run"],
    ans: 1,
    expl: "In the long run, the firm has enough time to adjust all inputs including capital."
  },
  {
