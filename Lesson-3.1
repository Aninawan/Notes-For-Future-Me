  .choice-btn.selected { border-color: var(--slate); background: #e8edf0; }
  .choice-btn.correct { border-color: var(--correct); background: #e8f5e9; }
  .choice-btn.wrong { border-color: var(--wrong); background: #fce4ec; }
  .choice-btn.reveal-correct { border-color: var(--correct); background: #e8f5e9; }
