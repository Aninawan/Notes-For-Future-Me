    font-size: 0.75rem;
    display: block;
    margin-bottom: 0.3rem;
  }

  .stage-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }
  .stage-box {
    border-radius: 4px;
    padding: 1rem;
    font-size: 0.82rem;
  }
  .stage-box h4 { font-weight: 700; margin-bottom: 0.5rem; font-size: 0.85rem; }
  .stage-box ul { padding-left: 1rem; line-height: 1.9; }
  .stage-1 { background: #e8f5e9; border-left: 3px solid #4caf50; }
  .stage-2 { background: #fff8e1; border-left: 3px solid #ffc107; }
  .stage-3 { background: #fce4ec; border-left: 3px solid #e91e63; }

  .rts-table { width: 100%; border-collapse: collapse; margin-top: 1rem; font-size: 0.88rem; }
  .rts-table th { background: var(--ink); color: var(--gold); padding: 0.6rem 1rem; text-align: left; font-weight: 600; }
  .rts-table td { padding: 0.6rem 1rem; border-bottom: 1px solid var(--border); }
  .rts-table tr:last-child td { border-bottom: none; }
